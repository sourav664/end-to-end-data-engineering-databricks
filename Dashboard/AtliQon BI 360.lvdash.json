{
  "datasets": [
    {
      "name": "b036bb3c",
      "displayName": "vw_fact_orders_enriched",
      "queryLines": [
        "SELECT * FROM fmcg.gold.vw_fact_orders_enriched"
      ]
    },
    {
      "name": "72511a66",
      "displayName": "Orders Data Filtered by Channel Presence",
      "queryLines": [
        "select * from fmcg.gold.vw_fact_orders_enriched\r\n",
        "where channel is not null;"
      ]
    },
    {
      "name": "295b2227",
      "displayName": "all customers by revenue",
      "queryLines": [
        "select customer, sum(sold_quantity) as quantity, sum(total_amount_inr) as revenue, avg(price_inr) as Price from fmcg.gold.vw_fact_orders_enriched\r\n",
        "where channel is not null\r\n",
        "group by customer"
      ]
    },
    {
      "name": "730eebd1",
      "displayName": "all category by quanity",
      "queryLines": [
        "select category, sum(sold_quantity) as quantity, avg(price_inr) as price from fmcg.gold.vw_fact_orders_enriched\r\n",
        "where channel is not null\r\n",
        "group by category"
      ]
    },
    {
      "name": "ae1c1931",
      "displayName": "all platform by revenue",
      "queryLines": [
        "SELECT * FROM fmcg.gold.vw_fact_orders_enriched\r\n",
        "where platform is not NULL"
      ]
    },
    {
      "name": "2d1b9549",
      "displayName": "all division by revenue",
      "queryLines": [
        "SELECT platform, division, sum(total_amount_inr) as revenue FROM fmcg.gold.vw_fact_orders_enriched\r\n",
        "where platform is not NULL\r\n",
        "group by platform, division\r\n",
        "ORDER BY revenue DESC limit 20"
      ]
    }
  ],
